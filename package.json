{
  "name": "deepyomi",
  "version": "1.0.0",
  "description": "Electron desktop app that OCRs vertical Japanese light-novel pages and opens the text in DeepL for translation.",
  "main": "src/main.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./src/output.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./src/output.css --watch",
    "start": "npm run build:css && electron ."
  },
  "keywords": [
    "electron",
    "ocr",
    "japanese",
    "tesseract",
    "deepl",
    "light-novel"
  ],
  "author": "Muhamad Umair",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "tailwindcss": "^3.4.19"
  }
}
